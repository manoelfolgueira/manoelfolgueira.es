<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
  .calc-card {
    background: #0f172a; /* Igualado al bg-slate-900 del index */
    border-radius: 1rem;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.3);
    border: 1px solid #1e293b; /* border-slate-800 */
  }
  .calc-card h1, .calc-card h2 {
    margin-top: 0;
    color: #f9fafb;
    font-weight: 800;
  }
  .calc-card h1 { font-size: 1.8rem; margin-bottom: 0.5rem; }
  .calc-card h2 { font-size: 1.3rem; margin-bottom: 1rem; margin-top: 1.5rem; }
  .calc-card label {
    display: block;
    font-size: 0.9rem;
    margin-bottom: 0.25rem;
    color: #cbd5f5;
  }
  .calc-card input[type="number"],
  .calc-card input[type="range"] {
    width: 100%;
  }
  .calc-card input[type="number"] {
    padding: 0.4rem 0.5rem;
    border-radius: 0.375rem;
    border: 1px solid #334155;
    background: #020617; /* Fondo más oscuro solo para inputs */
    color: #e5e7eb;
    box-sizing: border-box;
  }
  .calc-card select {
    width: 100%;
    padding: 0.4rem 0.5rem;
    border-radius: 0.375rem;
    border: 1px solid #334155;
    background: #020617;
    color: #e5e7eb;
  }
  .range-wrapper {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .range-wrapper span {
    font-size: 0.85rem;
    min-width: 3.5rem;
    text-align: right;
    color: #9ca3af;
  }
  .calc-card input[type="range"] {
    accent-color: #10b981;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.75rem;
    background: rgba(16, 185, 129, 0.1);
    border: 1px solid rgba(16, 185, 129, 0.3);
    color: #6ee7b7;
  }
  .pill {
    display: inline-block;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    font-size: 0.7rem;
    background: rgba(148, 163, 184, 0.2);
    color: #e5e7eb;
    margin-left: 0.25rem;
  }
  .results-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }
  @media (min-width: 768px) {
    .results-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
  .result-box {
    background: radial-gradient(circle at top left, #1e293b, #0f172a);
    border-radius: 0.9rem;
