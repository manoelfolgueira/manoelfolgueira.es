    font-size: 0.8rem;
    color: #94a3b8;
  }
  .result-main {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 0.25rem;
    margin-bottom: 0.25rem;
    color: #f8fafc;
  }
  .result-sub {
    font-size: 0.75rem;
    color: #64748b;
  }
  .highlight {
    color: #10b981;
  }
  canvas {
    background: #020617;
    border-radius: 0.75rem;
    border: 1px solid #1e293b;
    padding: 0.5rem;
  }
  .btn-calc {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    border: 1px solid #10b981;
    background: #064e3b;
    color: #6ee7b7;
    font-size: 0.85rem;
    cursor: pointer;
    margin-top: 0.5rem;
    transition: background 0.2s;
  }
  .btn-calc:hover {
    background: #022c22;
  }
  .br-summary {
    margin-top: 0.8rem;
    font-size: 0.85rem;
