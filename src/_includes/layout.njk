<!DOCTYPE html>
<html lang="es" class="bg-slate-900 text-slate-100">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>{% if title %}{{ title }} | manoelfolgueira.es{% else %}manoelfolgueira.es | Finanzas Personales Sistemáticas{% endif %}</title>
    <meta name="description" content="{{ description | default('Herramientas avanzadas y simuladores matemáticos independientes para la optimización del patrimonio, interés compuesto y estrategia FIRE.') }}">
    <link rel="canonical" href="https://www.manoelfolgueira.es{{ permalink }}">

    <meta property="og:site_name" content="manoelfolgueira.es">
    <meta property="og:title" content="{% if title %}{{ title }}{% else %}Optimización Financiera Sistemática{% endif %}">
    <meta property="og:description" content="{{ description | default('Simuladores matemáticos y modelos de planificación financiera local-first.') }}">
    <meta property="og:url" content="https://www.manoelfolgueira.es{{ permalink }}">
    <meta property="og:type" content="website">
    <meta property="og:image" content="https://www.manoelfolgueira.es/res/img/og-preview.jpg">

    <link rel="icon" type="image/svg+xml" href="/res/img/favicon.svg">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen font-sans">
    <header class="border-b border-slate-800 bg-slate-950/80 backdrop-blur-md sticky top-0 z-50">
      <nav class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-3 group">
              <div class="w-10 h-10 rounded-full bg-slate-800 overflow-hidden border border-slate-700 group-hover:border-emerald-500 transition-colors">
                  <img src="/res/img/image_1b7492.png" alt="Manoel Folgueira" class="w-full h-full object-cover">
              </div>
              <span class="text-xl font-bold text-white tracking-tight">
                  manoel<span class="text-emerald-500">folgueira.es</span>
              </span>
          </a>

          <!-- Menú Derecho -->
          <div class="flex items-center gap-4 sm:gap-6">
              <!-- Enlace estándar -->
              <a href="/" class="text-sm font-medium text-slate-400 hover:text-emerald-400 transition">Panel</a>

              <!-- Botón Buy Me a Coffee (Escritorio) -->
              <a href="https://ko-fi.com/manoelfolgueira" target="_blank" rel="noopener noreferrer" 
                 class="hidden sm:flex items-center gap-2 px-4 py-2 bg-slate-800/80 hover:bg-slate-700 border border-slate-700 hover:border-slate-500 rounded-xl text-sm font-semibold text-slate-200 transition shadow-lg shadow-slate-900/20 group">
                  <span class="group-hover:scale-110 transition-transform origin-bottom">☕</span>
                  <span>Invítame a un café</span>
              </a>
              
              <!-- Botón Buy Me a Coffee (Móvil - Solo icono) -->
              <a href="https://ko-fi.com/manoelfolgueira" target="_blank" rel="noopener noreferrer" 
                 class="sm:hidden flex items-center justify-center w-9 h-9 bg-slate-800/80 hover:bg-slate-700 border border-slate-700 hover:border-slate-500 rounded-xl text-base transition shadow-lg group">
                  <span class="group-hover:scale-110 transition-transform origin-bottom">☕</span>
              </a>
          </div>
      </nav>
  </header>
    <main class="max-w-6xl mx-auto px-6 py-12">
        {{ content | safe }}
    </main>
    <footer class="border-t border-slate-800 mt-24 py-12">
      <div class="max-w-6xl mx-auto px-6 text-center">
          <p class="text-slate-500 text-sm mb-4">
              © 2026 Manoel Folgueira. Todos los derechos reservados.
          </p>
          <div class="flex justify-center gap-6">
              <a href="mailto:manoel.folgueira@gmail.com" class="text-slate-400 hover:text-emerald-400 transition text-sm">Contacto</a>
          </div>
      </div>
    </footer>
</body>
</html>