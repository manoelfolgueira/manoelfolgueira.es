---
layout: layout.njk
title: Panel
---

<div class="space-y-16 py-6" style="scroll-behavior: smooth;">
    
    <a href="/" class="group flex items-center gap-6 p-8 rounded-2xl bg-slate-900 border border-slate-800 hover:border-slate-700 transition shadow-lg">
        <div class="flex-shrink-0 w-16 h-16 rounded-2xl bg-emerald-900/30 flex items-center justify-center text-emerald-400 group-hover:scale-105 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>
        <div>
            <h2 class="text-2xl font-bold text-white mb-1 group-hover:text-emerald-400 transition-colors">Guía: Optimización Financiera desde Cero</h2>
            <p class="text-slate-400">El camino estructurado para pasar del caos a la independencia financiera. Ideal si estás empezando.</p>
        </div>
    </a>

    <section id="documentacion" class="scroll-mt-24">
        <h3 class="text-xl font-bold text-white mb-6 border-b border-slate-800 pb-2">Documentación</h3>
        
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            <div class="p-8 rounded-2xl bg-slate-900/50 border border-slate-800 border-dashed flex flex-col justify-center items-center text-center min-h-[220px]">
                <span class="text-2xl mb-2 opacity-50">📄</span>
                <h4 class="text-lg font-bold text-slate-400 mb-1">Próximos artículos</h4>
                <p class="text-sm text-slate-500">Aquí se añadirán las guías de inversión y filosofía de optimización.</p>
            </div>
        </div>
    </section>

    <section id="herramientas" class="scroll-mt-24">
        <h3 class="text-xl font-bold text-white mb-6 border-b border-slate-800 pb-2">Herramientas</h3>
        
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            {% set tools = [
                { 
                    title: "Simulador de Jubilación", 
                    desc: "Calcula tu pensión futura, último sueldo y equivalente en euros de hoy.", 
                    icon: "👴🏼", 
                    url: "/apps/jubilacion/", 
                    label: "Acceder directamente" 
                }
            ] %}
            
            {% for item in tools %}
            <div class="p-8 rounded-2xl bg-slate-900 border border-slate-800 shadow-lg flex flex-col justify-between hover:border-slate-700 transition">
                <div>
                    <div class="text-3xl mb-4">{{ item.icon }}</div>
                    <h4 class="text-xl font-bold text-white mb-2">{{ item.title }}</h4>
                    <p class="text-slate-400 text-sm mb-6 leading-relaxed">{{ item.desc }}</p>
                </div>
                
                <div class="flex items-center gap-2 mt-4 pt-4 border-t border-slate-800/60">
                    <a href="{{ item.url }}" class="flex-1 text-center py-2.5 px-4 bg-slate-800/40 hover:bg-slate-800 border border-slate-700/40 hover:border-slate-500 rounded-xl text-xs font-semibold text-slate-200 hover:text-white transition group/btn flex items-center justify-center gap-1.5">
                        <span>{{ item.label }}</span>
                        <span class="inline-block transition-transform group-hover/btn:translate-x-0.5">→</span>
                    </a>
                    
                    <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer" class="p-2.5 bg-slate-800/20 hover:bg-slate-800/60 border border-slate-800 hover:border-slate-500 rounded-xl text-slate-400 hover:text-emerald-400 transition" title="Abrir en una pestaña adicional">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                    </a>
                </div>
            </div>
            {% endfor %}
        </div>
    </section>

</div>