---
layout: layout.njk
title: Panel
---

<div class="space-y-12 py-6" style="scroll-behavior: smooth;">
    
    <!-- Centro de Control (Buscador integrado) -->
    <div class="bg-slate-900/50 border border-slate-800 p-8 rounded-3xl">
        <h1 class="text-3xl font-bold text-white mb-2">Centro de Control</h1>
        <p class="text-slate-400 mb-8">Utiliza el buscador para localizar rápidamente cualquier recurso, artículo o herramienta de gestión.</p>

        <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
            </div>
            <input type="text" id="buscador" placeholder="Buscar artículos y aplicaciones..." 
                   class="w-full bg-slate-950 border border-slate-700 focus:border-emerald-500 text-white rounded-2xl pl-12 pr-4 py-5 shadow-inner focus:outline-none transition placeholder-slate-600 text-lg">
        </div>
    </div>

    <!-- SECCIÓN: ARTÍCULOS (Generación Dinámica) -->
    <section id="articulos" class="scroll-mt-24 search-section">
        <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-3">
            <span class="w-1.5 h-6 bg-emerald-500 rounded-full"></span> Artículos
        </h3>
        
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            {% for post in collections.articulos %}
            <div class="searchable-item p-8 rounded-2xl bg-slate-900 border border-slate-800 shadow-lg flex flex-col justify-between hover:border-slate-700 transition"
                 data-title="{{ post.data.title }}" 
                 data-desc="{{ post.data.description }}">
                
                <div>
                    <div class="text-3xl mb-4">{{ post.data.icon | default('📄') }}</div>
                    <h4 class="text-xl font-bold text-white mb-2">{{ post.data.title }}</h4>
                    <p class="text-slate-400 text-sm mb-6 leading-relaxed">{{ post.data.description }}</p>
                </div>
                
                <div class="mt-4 pt-4 border-t border-slate-800/60">
                    <a href="{{ post.url }}" target="_blank" rel="noopener noreferrer" class="w-full py-2.5 px-4 bg-slate-800/40 hover:bg-slate-800 border border-slate-700/40 hover:border-slate-500 rounded-xl text-xs font-semibold text-slate-200 hover:text-white transition flex items-center justify-center gap-1.5">
                        <span>Leer artículo</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                    </a>
                </div>
            </div>
            {% endfor %}
        </div>
        
        <div class="no-results hidden mt-8 text-center py-8 text-slate-500 border border-slate-800 border-dashed rounded-2xl bg-slate-900/30">
            No se han encontrado resultados en esta categoría.
        </div>
    </section>

    <!-- SECCIÓN: APLICACIONES (Generación Dinámica) -->
    <section id="aplicaciones" class="scroll-mt-24 search-section">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-6 gap-4">
            <h3 class="text-xl font-bold text-white flex items-center gap-3">
                <span class="w-1.5 h-6 bg-emerald-500 rounded-full"></span> Aplicaciones
            </h3>
            <div class="flex gap-2">
                <button onclick="document.getElementById('fileImport').click()" class="px-3 py-1.5 text-xs font-medium bg-slate-800/50 hover:bg-slate-700 text-slate-300 rounded-lg border border-slate-700 transition flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
                    Importar Configuración
                </button>
                <button onclick="exportarConfig()" class="px-3 py-1.5 text-xs font-medium bg-slate-800/50 hover:bg-slate-700 text-slate-300 rounded-lg border border-slate-700 transition flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                    Exportar Configuración
                </button>
                <input type="file" id="fileImport" class="hidden" accept=".json" onchange="importarConfig(event)">
            </div>
        </div>
        
        <p class="text-xs text-slate-500 mb-8 italic">
            Las configuraciones se guardan en tu navegador. Usa los botones superiores para exportar tus ajustes o importar una configuración desde otro equipo o navegador.
        </p>
        
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            {% for item in collections.aplicaciones %}
            <div class="searchable-item p-8 rounded-2xl bg-slate-900 border border-slate-800 shadow-lg flex flex-col justify-between hover:border-slate-700 transition"
                 data-title="{{ item.data.title }}" 
                 data-desc="{{ item.data.description }}">
                
                <div>
                    <div class="text-3xl mb-4">{{ item.data.icon | default('⚙️') }}</div>
                    <h4 class="text-xl font-bold text-white mb-2">{{ item.data.title }}</h4>
                    <p class="text-slate-400 text-sm mb-6 leading-relaxed">{{ item.data.description }}</p>
                </div>
                
                <div class="flex items-center gap-2 mt-4 pt-4 border-t border-slate-800/60">
                    <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer" class="flex-1 text-center py-2.5 px-4 bg-slate-800/40 hover:bg-slate-800 border border-slate-700/40 hover:border-slate-500 rounded-xl text-xs font-semibold text-slate-200 hover:text-white transition flex items-center justify-center gap-1.5">
                        <span>Abrir aplicación</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                    </a>
                </div>
            </div>
            {% endfor %}
        </div>
        
        <div class="no-results hidden mt-8 text-center py-8 text-slate-500 border border-slate-800 border-dashed rounded-2xl bg-slate-900/30">
            No se han encontrado resultados en esta categoría.
        </div>
    </section>

</div>

<script>
    document.getElementById('buscador').addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase().trim();
        document.querySelectorAll('.search-section').forEach(seccion => {
            const items = seccion.querySelectorAll('.searchable-item');
            let visibles = 0;
            
            items.forEach(item => {
                const title = item.getAttribute('data-title').toLowerCase();
                const desc = item.getAttribute('data-desc').toLowerCase();
                const match = title.includes(query) || desc.includes(query);
                
                item.style.display = match ? '' : 'none';
                if (match) visibles++;
            });
            
            const noResults = seccion.querySelector('.no-results');
            if (noResults) {
                noResults.classList.toggle('hidden', visibles > 0);
            }
        });
    });

    function exportarConfig() {
        const data = localStorage.getItem('mf_aplicaciones_config') || '{}';
        const blob = new Blob([data], { type: "application/json" });
        const url = URL.createObjectURL(blob);
        
        const a = document.createElement('a');
        a.href = url;
        a.download = "manoelfolgueira_config.json";
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    }

    function importarConfig(event) {
        const file = event.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = function(e) {
            try {
                const json = JSON.parse(e.target.result);
                localStorage.setItem('mf_aplicaciones_config', JSON.stringify(json));
                alert("✅ Configuración importada con éxito.\n\nLos datos se aplicarán automáticamente al abrir las aplicaciones.");
            } catch (err) {
                alert("❌ Error: El archivo no tiene el formato correcto.");
            }
            event.target.value = ''; 
        };
        reader.readAsText(file);
    }
</script>