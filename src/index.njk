---
layout: layout.njk
title: Dashboard
---

<div class="space-y-12 py-6">
    <a href="/guia" class="block p-10 rounded-3xl bg-slate-900 border border-slate-800 hover:border-emerald-500/30 transition shadow-2xl">
        <h2 class="text-3xl font-bold text-white mb-2">Guía Desde Cero</h2>
        <p class="text-slate-400 text-lg">El mapa completo para optimizar tus finanzas desde la base.</p>
    </a>

    <div class="grid gap-8 md:grid-cols-2">
        {% set tools = [
            { title: "Calculadora FIRE", desc: "Planifica tu retiro.", icon: "🛡️" },
            { title: "Fondos Indexados", desc: "Gestión de carteras.", icon: "📈" }
        ] %}
        
        {% for item in tools %}
        <div class="group p-8 rounded-2xl bg-slate-900 border border-slate-800 hover:border-slate-700 transition">
            <div class="text-3xl mb-4">{{ item.icon }}</div>
            <h4 class="text-xl font-bold text-white mb-2">{{ item.title }}</h4>
            <p class="text-slate-400 mb-6">{{ item.desc }}</p>
            <span class="text-emerald-400 font-mono text-sm">→ Abrir recurso</span>
        </div>
        {% endfor %}
    </div>
</div>