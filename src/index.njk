---
layout: layout.njk
title: Panel
---

<div class="space-y-16 py-6" style="scroll-behavior: smooth;">
    
    <!-- BUSCADOR DINÁMICO -->
    <div class="relative">
        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
            <svg class="h-5 w-5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
        </div>
        <input type="text" id="buscador" placeholder="Buscar aplicaciones, documentos, calculadoras..." class="w-full bg-slate-900/80 border border-slate-800 focus:border-emerald-500 text-white rounded-xl pl-12 pr-4 py-4 shadow-lg focus:outline-none focus:ring-1 focus:ring-emerald-500 transition placeholder-slate-500 text-lg">
    </div>

    <!-- SECCIÓN: ARTÍCULOS -->
    <section id="artículos" class="scroll-mt-24 search-section">
        <h3 class="text-xl font-bold text-white mb-6 border-b border-slate-800 pb-2 section-title">Artículos</h3>
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            <div class="searchable-item p-8 rounded-2xl bg-slate-900 border border-slate-800 shadow-lg flex flex-col justify-between hover:border-slate-700 transition"
                 data-title="Optimiza la gestión de tu dinero desde cero" 
                 data-desc="El mapa estructurado para pasar del caos financiero a la inversión sistemática.">
                 
                <div>
                    <div class="text-3xl mb-4">🚀</div>
                    <h4 class="text-xl font-bold text-white mb-2">Optimiza la gestión de tu dinero desde cero</h4>
                    <p class="text-slate-400 text-sm mb-6 leading-relaxed">El mapa estructurado para pasar del caos financiero a la inversión sistemática.</p>
                </div>
                
                <div class="mt-4 pt-4 border-t border-slate-800/60">
                    <a href="/articulos/optimizacion-desde-cero/" class="w-full py-2.5 px-4 bg-slate-800/40 hover:bg-slate-800 border border-slate-700/40 hover:border-slate-500 rounded-xl text-xs font-semibold text-slate-200 hover:text-white transition group/btn flex items-center justify-center gap-1.5">
                        <span>Leer artículo</span>
                        <span class="inline-block transition-transform group-hover/btn:translate-x-0.5">→</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- SECCIÓN: APLICACIONES -->
    <section id="aplicaciones" class="scroll-mt-24 search-section">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-4 border-b border-slate-800 pb-2 gap-4">
            <h3 class="text-xl font-bold text-white section-title">Aplicaciones</h3>
            <div class="flex gap-2">
                <button onclick="document.getElementById('fileImport').click()" class="px-3 py-1.5 text-xs font-medium bg-slate-800/50 hover:bg-slate-700 text-slate-300 rounded-lg border border-slate-700 transition flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
                    Importar Configuración
                </button>
                <button onclick="exportarConfig()" class="px-3 py-1.5 text-xs font-medium bg-slate-800/50 hover:bg-slate-700 text-slate-300 rounded-lg border border-slate-700 transition flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                    Exportar Configuración
                </button>
                <input type="file" id="fileImport" class="hidden" accept=".json" onchange="importarConfig(event)">
            </div>
        </div>
        
        <p class="text-xs text-slate-500 mb-8 italic section-desc">
            Las configuraciones se guardan en tu navegador. Usa los botones superiores para exportar tus ajustes o importar una configuración desde otro equipo o navegador.
        </p>
        
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            <!-- Datos de tus aplicaciones (Aviso: Variable cambiada a aplicaciones) -->
            {% set aplicaciones = [
                { 
                    title: "Interés Compuesto", 
                    desc: "Proyecciones patrimoniales de alta fidelidad con inflación y cálculo de IRPF progresivo por tramos.", 
                    icon: "📈", 
                    url: "/aplicaciones/interes-compuesto/", 
                    label: "Abrir calculadora" 
                },
                { 
                    title: "Simulador de Jubilación", 
                    desc: "Calcula tu pensión futura, último sueldo y equivalente en euros de hoy.", 
                    icon: "👴🏼", 
                    url: "/aplicaciones/jubilacion/", 
                    label: "Abrir aplicación" 
                }
            ] %}
            
            {% for item in aplicaciones %}
            <div class="searchable-item p-8 rounded-2xl bg-slate-900 border border-slate-800 shadow-lg flex flex-col justify-between hover:border-slate-700 transition"
                 data-title="{{ item.title }}" 
                 data-desc="{{ item.desc }}">
                 
                <div>
                    <div class="text-3xl mb-4">{{ item.icon }}</div>
                    <h4 class="text-xl font-bold text-white mb-2">{{ item.title }}</h4>
                    <p class="text-slate-400 text-sm mb-6 leading-relaxed">{{ item.desc }}</p>
                </div>
                
                <div class="flex items-center gap-2 mt-4 pt-4 border-t border-slate-800/60">
                    <a href="{{ item.url }}" class="flex-1 text-center py-2.5 px-4 bg-slate-800/40 hover:bg-slate-800 border border-slate-700/40 hover:border-slate-500 rounded-xl text-xs font-semibold text-slate-200 hover:text-white transition group/btn flex items-center justify-center gap-1.5">
                        <span>{{ item.label }}</span>
                        <span class="inline-block transition-transform group-hover/btn:translate-x-0.5">→</span>
                    </a>
                    <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer" class="p-2.5 bg-slate-800/20 hover:bg-slate-800/60 border border-slate-800 hover:border-slate-500 rounded-xl text-slate-400 hover:text-emerald-400 transition" title="Abrir en una pestaña adicional">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                    </a>
                </div>
            </div>
            {% endfor %}
        </div>
        
        <div class="no-results hidden col-span-full text-center py-8 text-slate-500 border border-slate-800 border-dashed rounded-2xl bg-slate-900/30">
            No se han encontrado resultados en esta categoría.
        </div>
    </section>

</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const buscador = document.getElementById('buscador');
        const secciones = document.querySelectorAll('.search-section');

        buscador.addEventListener('input', (e) => {
            const query = e.target.value.toLowerCase().trim();

            secciones.forEach(seccion => {
                const items = seccion.querySelectorAll('.searchable-item');
                let itemsVisibles = 0;

                items.forEach(item => {
                    const title = item.getAttribute('data-title').toLowerCase();
                    const desc = item.getAttribute('data-desc').toLowerCase();
                    
                    if (title.includes(query) || desc.includes(query)) {
                        item.style.display = '';
                        itemsVisibles++;
                    } else {
                        item.style.display = 'none';
                    }
                });

                const noResultsMsg = seccion.querySelector('.no-results');
                if (noResultsMsg) {
                    if (itemsVisibles === 0 && items.length > 0) {
                        noResultsMsg.classList.remove('hidden');
                    } else {
                        noResultsMsg.classList.add('hidden');
                    }
                }
            });
        });
    });

    function exportarConfig() {
        const data = localStorage.getItem('mf_aplicaciones_config') || '{}';
        const blob = new Blob([data], { type: "application/json" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = "manoelfolgueira_config.json";
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    }

    function importarConfig(event) {
        const file = event.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = function(e) {
            try {
                const json = JSON.parse(e.target.result);
                localStorage.setItem('mf_aplicaciones_config', JSON.stringify(json));
                alert("✅ Configuración importada con éxito.\n\nLos datos se aplicarán automáticamente al abrir las aplicaciones.");
            } catch (err) {
                alert("❌ Error: El archivo no tiene el formato correcto.");
            }
            event.target.value = ''; 
        };
        reader.readAsText(file);
    }
</script>