---
layout: layout.njk
title: Panel
---

<div class="space-y-12 py-6" style="scroll-behavior: smooth;">

    <!-- HERO BANNER: Propuesta de Valor -->
    <div class="relative overflow-hidden rounded-3xl bg-slate-900 border border-emerald-500/30 p-8 sm:p-12 text-center shadow-2xl shadow-emerald-900/10">
        <!-- Efecto de resplandor de fondo -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-full bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-emerald-900/40 via-transparent to-transparent pointer-events-none"></div>

        <div class="relative z-10 max-w-3xl mx-auto">
            <!-- Etiqueta superior -->
            <div class="mb-6">
                <span class="inline-flex items-center gap-1.5 py-1.5 px-4 rounded-full bg-emerald-500/10 text-emerald-400 text-sm font-semibold tracking-wide border border-emerald-500/20">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" /></svg>
                    Impacto en menos de 7 días
                </span>
            </div>
            
            <!-- Título Principal -->
            <h2 class="text-3xl sm:text-5xl font-extrabold text-white tracking-tight mb-6 leading-tight">
                Transforma tu situación financiera en <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-cyan-400">menos de una semana</span>.
            </h2>
            
            <!-- Eslogan (Engineering financial independence...) -->
            <p class="text-lg sm:text-xl text-slate-300 mb-10 leading-relaxed max-w-2xl mx-auto">
                Te ayudo a construir, automatizar y escalar un sistema patrimonial a prueba de fallos.
            </p>
            
            <!-- Eslogan y advertencia realista con enfoque educativo -->
            <p class="text-lg sm:text-xl text-slate-300 mb-6 leading-relaxed max-w-2xl mx-auto">
                Esto no es una fórmula mágica para ganar un millón en dos días. Aprenderás a diseñar un sistema que haga crecer tu dinero de forma sólida y dominarás los conceptos clave para que, en el futuro, sepas gestionarlo con total autonomía.
            </p>

            <!-- Aclaración: Qué NO es un sistema -->
            <div class="max-w-lg mx-auto mb-10 text-left bg-slate-800/40 border border-slate-700/50 rounded-2xl p-5 sm:p-6 shadow-inner">
                <p class="text-emerald-400 font-bold mb-3 text-xs uppercase tracking-wider text-center sm:text-left">Entiende la diferencia:</p>
                <ul class="space-y-3 text-slate-300 text-sm sm:text-base">
                    <li class="flex items-start gap-2.5">
                        <span class="text-red-400/80 font-bold mt-0.5">✕</span> 
                        <span>Tener un fondo de emergencia <strong class="text-slate-100 font-medium">no significa tener un Sistema Financiero Robusto</strong>.</span>
                    </li>
                    <li class="flex items-start gap-2.5">
                        <span class="text-red-400/80 font-bold mt-0.5">✕</span> 
                        <span>Tener una cuenta remunerada <strong class="text-slate-100 font-medium">no significa tener un Sistema Financiero Robusto</strong>.</span>
                    </li>
                    <li class="flex items-start gap-2.5">
                        <span class="text-red-400/80 font-bold mt-0.5">✕</span> 
                        <span>Invertir de forma aislada <strong class="text-slate-100 font-medium">no significa tener un Sistema Financiero Robusto</strong>.</span>
                    </li>
                    <li class="flex items-start gap-2.5 mt-4 pt-4 border-t border-slate-700/50">
                        <span class="text-emerald-500 font-bold mt-0.5">✓</span> 
                        <span class="text-slate-100">Un sistema es la <strong>arquitectura</strong> que conecta todas esas piezas y más para que trabajen juntas armónicamente.</span>
                    </li>
                </ul>
            </div>

            <!-- Contenedor de Botones y Contacto -->
            <div class="flex flex-col items-center gap-5">
                
                <!-- Botón CTA a la guía principal -->
                <a href="/articulos/optimizacion-desde-cero/" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-emerald-600 hover:bg-emerald-500 text-white font-bold rounded-2xl transition-all duration-300 shadow-lg shadow-emerald-900/50 hover:shadow-emerald-500/30 transform hover:-translate-y-1">
                    <span>Construir mi sistema paso a paso</span>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" /></svg>
                </a>

                <!-- Mensaje secundario con botón de WhatsApp en línea -->
                <p class="text-sm sm:text-base text-slate-400 flex flex-col sm:flex-row items-center gap-3">
                    O si prefieres que te ayude personalmente, contáctame por 
                    <a href="https://wa.me/34607864206" target="_blank" rel="noopener noreferrer" 
                       class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-slate-800/80 hover:bg-slate-700 border border-slate-700 hover:border-emerald-500 rounded-lg text-sm font-semibold text-slate-200 transition shadow-sm group">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4 text-emerald-400 group-hover:scale-110 transition-transform origin-bottom">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
                        </svg>
                        WhatsApp
                    </a>
                </p>
                
            </div>
            
            <div class="flex flex-col items-center gap-5 mt-4">
                                
                <!-- GRÁFICO: El Sistema Financiero Óptimo -->
                <div class="my-12 p-6 sm:p-10 rounded-3xl bg-slate-900/50 border border-slate-800 shadow-xl">
                    <h3 class="text-2xl font-bold text-white mb-8 text-center">Hoja de Ruta del Sistema Patrimonial</h3>
                    
                    <div class="relative border-l-2 border-emerald-500/30 ml-4 sm:ml-8 space-y-12">
                        
                        <!-- Fase 1 -->
                        <div class="relative pl-8 sm:pl-12">
                            <!-- Nodo -->
                            <div class="absolute -left-[17px] top-1 h-8 w-8 rounded-full bg-slate-900 border-2 border-emerald-500 flex items-center justify-center text-emerald-400 text-sm font-bold shadow-[0_0_15px_rgba(16,185,129,0.3)]">
                                1
                            </div>
                            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-800 text-slate-300 text-xs font-semibold tracking-wide mb-3">
                                🛡️ Defensa
                            </div>
                            <h4 class="text-xl font-bold text-white mb-2">Contención y Riesgos</h4>
                            <p class="text-slate-400 text-sm mb-3">Estabilización del balance y creación del muro de seguridad.</p>
                            <ul class="space-y-1 text-sm text-slate-300">
                                <li class="flex items-start gap-2"><span class="text-emerald-500 mt-0.5">▪</span> Auditoría y eliminación de deuda tóxica (TIN > 6%).</li>
                                <li class="flex items-start gap-2"><span class="text-emerald-500 mt-0.5">▪</span> Dimensionamiento del Fondo de Emergencia (Supervivencia operativa).</li>
                                <li class="flex items-start gap-2"><span class="text-emerald-500 mt-0.5">▪</span> Externalización de riesgos inasumibles (Seguros RC y Hogar).</li>
                            </ul>
                        </div>

                        <!-- Fase 2 -->
                        <div class="relative pl-8 sm:pl-12">
                            <!-- Nodo -->
                            <div class="absolute -left-[17px] top-1 h-8 w-8 rounded-full bg-slate-900 border-2 border-emerald-500 flex items-center justify-center text-emerald-400 text-sm font-bold shadow-[0_0_15px_rgba(16,185,129,0.3)]">
                                2
                            </div>
                            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-800 text-slate-300 text-xs font-semibold tracking-wide mb-3">
                                ⚙️ Motor
                            </div>
                            <h4 class="text-xl font-bold text-white mb-2">Estrategia de Crecimiento</h4>
                            <p class="text-slate-400 text-sm mb-3">Despliegue del capital en activos productivos sin fricción emocional.</p>
                            <ul class="space-y-1 text-sm text-slate-300">
                                <li class="flex items-start gap-2"><span class="text-emerald-500 mt-0.5">▪</span> Automatización de aportaciones periódicas (DCA).</li>
                                <li class="flex items-start gap-2"><span class="text-emerald-500 mt-0.5">▪</span> Arquitectura indexada de bajo coste (Distribución S&P 500 / Global).</li>
                                <li class="flex items-start gap-2"><span class="text-emerald-500 mt-0.5">▪</span> Aprovechamiento del diferimiento fiscal mediante traspasos.</li>
                            </ul>
                        </div>

                        <!-- Fase 3 -->
                        <div class="relative pl-8 sm:pl-12">
                            <!-- Nodo -->
                            <div class="absolute -left-[17px] top-1 h-8 w-8 rounded-full bg-slate-900 border-2 border-emerald-500 flex items-center justify-center text-emerald-400 text-sm font-bold shadow-[0_0_15px_rgba(16,185,129,0.3)]">
                                3
                            </div>
                            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-800 text-slate-300 text-xs font-semibold tracking-wide mb-3">
                                🚀 Aceleración
                            </div>
                            <h4 class="text-xl font-bold text-white mb-2">Optimización y Escalamiento</h4>
                            <p class="text-slate-400 text-sm mb-3">Incremento de la tracción matemática del patrimonio.</p>
                            <ul class="space-y-1 text-sm text-slate-300">
                                <li class="flex items-start gap-2"><span class="text-emerald-500 mt-0.5">▪</span> Escalado de aportaciones vinculadas al IPC anual.</li>
                                <li class="flex items-start gap-2"><span class="text-emerald-500 mt-0.5">▪</span> Financiación estratégica de pasivos mediante Pignoración (Lombard).</li>
                                <li class="flex items-start gap-2"><span class="text-emerald-500 mt-0.5">▪</span> Reducción de costes operativos vitales (Presupuesto y eficiencia).</li>
                            </ul>
                        </div>

                        <!-- Fase 4 -->
                        <div class="relative pl-8 sm:pl-12">
                            <!-- Nodo -->
                            <div class="absolute -left-[17px] top-1 h-8 w-8 rounded-full bg-emerald-500 border-2 border-emerald-400 flex items-center justify-center text-slate-900 text-sm font-bold shadow-[0_0_20px_rgba(16,185,129,0.5)]">
                                4
                            </div>
                            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-900/40 border border-emerald-500/30 text-emerald-400 text-xs font-semibold tracking-wide mb-3">
                                🏖️ Meta
                            </div>
                            <h4 class="text-xl font-bold text-white mb-2">Visión FIRE (Independencia)</h4>
                            <p class="text-slate-400 text-sm mb-3">Transición del capital acumulado a rentas de sostenimiento.</p>
                            <ul class="space-y-1 text-sm text-slate-300">
                                <li class="flex items-start gap-2"><span class="text-emerald-500 mt-0.5">▪</span> Cese laboral y activación de la regla de retiro (presupuesto deflactado).</li>
                                <li class="flex items-start gap-2"><span class="text-emerald-500 mt-0.5">▪</span> Cobertura de cotizaciones mediante Convenio Especial SS.</li>
                                <li class="flex items-start gap-2"><span class="text-emerald-500 mt-0.5">▪</span> Fusión final de rentas pasivas e ingresos estatales.</li>
                            </ul>
                        </div>
                        
                    </div>
                </div>
                
            </div>
        </div>
    </div>
    
    <!-- Centro de Control (Buscador integrado) -->
    <div class="bg-slate-900/50 border border-slate-800 p-8 rounded-3xl">
        <h1 class="text-3xl font-bold text-white mb-2">Centro de Control</h1>
        <p class="text-slate-400 mb-8">Utiliza el buscador para localizar rápidamente cualquier recurso, artículo o herramienta de gestión.</p>

        <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
            </div>
            <input type="text" id="buscador" placeholder="Buscar artículos y aplicaciones..." 
                   class="w-full bg-slate-950 border border-slate-700 focus:border-emerald-500 text-white rounded-2xl pl-12 pr-4 py-5 shadow-inner focus:outline-none transition placeholder-slate-600 text-lg">
        </div>
    </div>

    <!-- SECCIÓN: ARTÍCULOS (Generación Dinámica) -->
    <section id="articulos" class="scroll-mt-24 search-section">
        <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-3">
            <span class="w-1.5 h-6 bg-emerald-500 rounded-full"></span> Artículos
        </h3>
        
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            {% for post in collections.articulos %}
            <div class="searchable-item p-8 rounded-2xl bg-slate-900 border border-slate-800 shadow-lg flex flex-col justify-between hover:border-slate-700 transition"
                 data-title="{{ post.data.title }}" 
                 data-desc="{{ post.data.description }}">
                
                <div>
                    <div class="text-3xl mb-4">{{ post.data.icon | default('📄') }}</div>
                    <h4 class="text-xl font-bold text-white mb-2">{{ post.data.title }}</h4>
                    <p class="text-slate-400 text-sm mb-6 leading-relaxed">{{ post.data.description }}</p>
                </div>
                
                <div class="mt-4 pt-4 border-t border-slate-800/60">
                    <a href="{{ post.url }}" target="_blank" rel="noopener noreferrer" class="w-full py-2.5 px-4 bg-slate-800/40 hover:bg-slate-800 border border-slate-700/40 hover:border-slate-500 rounded-xl text-xs font-semibold text-slate-200 hover:text-white transition flex items-center justify-center gap-1.5">
                        <span>Leer artículo</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                    </a>
                </div>
            </div>
            {% endfor %}
        </div>
        
        <div class="no-results hidden mt-8 text-center py-8 text-slate-500 border border-slate-800 border-dashed rounded-2xl bg-slate-900/30">
            No se han encontrado resultados en esta categoría.
        </div>
    </section>

    <!-- SECCIÓN: APLICACIONES (Generación Dinámica) -->
    <section id="aplicaciones" class="scroll-mt-24 search-section">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between mb-6 gap-4">
            <h3 class="text-xl font-bold text-white flex items-center gap-3">
                <span class="w-1.5 h-6 bg-emerald-500 rounded-full"></span> Aplicaciones
            </h3>
            <div class="flex gap-2">
                <button onclick="document.getElementById('fileImport').click()" class="px-3 py-1.5 text-xs font-medium bg-slate-800/50 hover:bg-slate-700 text-slate-300 rounded-lg border border-slate-700 transition flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12" /></svg>
                    Importar Configuración
                </button>
                <button onclick="exportarConfig()" class="px-3 py-1.5 text-xs font-medium bg-slate-800/50 hover:bg-slate-700 text-slate-300 rounded-lg border border-slate-700 transition flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" /></svg>
                    Exportar Configuración
                </button>
                <input type="file" id="fileImport" class="hidden" accept=".json" onchange="importarConfig(event)">
            </div>
        </div>
        
        <p class="text-xs text-slate-500 mb-8 italic">
            Las configuraciones se guardan en tu navegador. Usa los botones superiores para exportar tus ajustes o importar una configuración desde otro equipo o navegador.
        </p>
        
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            {% for item in collections.aplicaciones %}
            <div class="searchable-item p-8 rounded-2xl bg-slate-900 border border-slate-800 shadow-lg flex flex-col justify-between hover:border-slate-700 transition"
                 data-title="{{ item.data.title }}" 
                 data-desc="{{ item.data.description }}">
                
                <div>
                    <div class="text-3xl mb-4">{{ item.data.icon | default('⚙️') }}</div>
                    <h4 class="text-xl font-bold text-white mb-2">{{ item.data.title }}</h4>
                    <p class="text-slate-400 text-sm mb-6 leading-relaxed">{{ item.data.description }}</p>
                </div>
                
                <div class="flex items-center gap-2 mt-4 pt-4 border-t border-slate-800/60">
                    <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer" class="flex-1 text-center py-2.5 px-4 bg-slate-800/40 hover:bg-slate-800 border border-slate-700/40 hover:border-slate-500 rounded-xl text-xs font-semibold text-slate-200 hover:text-white transition flex items-center justify-center gap-1.5">
                        <span>Abrir aplicación</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                    </a>
                </div>
            </div>
            {% endfor %}
        </div>
        
        <div class="no-results hidden mt-8 text-center py-8 text-slate-500 border border-slate-800 border-dashed rounded-2xl bg-slate-900/30">
            No se han encontrado resultados en esta categoría.
        </div>
    </section>

</div>

<script>
    document.getElementById('buscador').addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase().trim();
        document.querySelectorAll('.search-section').forEach(seccion => {
            const items = seccion.querySelectorAll('.searchable-item');
            let visibles = 0;
            
            items.forEach(item => {
                const title = item.getAttribute('data-title').toLowerCase();
                const desc = item.getAttribute('data-desc').toLowerCase();
                const match = title.includes(query) || desc.includes(query);
                
                item.style.display = match ? '' : 'none';
                if (match) visibles++;
            });
            
            const noResults = seccion.querySelector('.no-results');
            if (noResults) {
                noResults.classList.toggle('hidden', visibles > 0);
            }
        });
    });

    function exportarConfig() {
        const data = localStorage.getItem('mf_aplicaciones_config') || '{}';
        const blob = new Blob([data], { type: "application/json" });
        const url = URL.createObjectURL(blob);
        
        const a = document.createElement('a');
        a.href = url;
        a.download = "manoelfolgueira_config.json";
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    }

    function importarConfig(event) {
        const file = event.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = function(e) {
            try {
                const json = JSON.parse(e.target.result);
                localStorage.setItem('mf_aplicaciones_config', JSON.stringify(json));
                alert("✅ Configuración importada con éxito.\n\nLos datos se aplicarán automáticamente al abrir las aplicaciones.");
            } catch (err) {
                alert("❌ Error: El archivo no tiene el formato correcto.");
            }
            event.target.value = ''; 
        };
        reader.readAsText(file);
    }
</script>