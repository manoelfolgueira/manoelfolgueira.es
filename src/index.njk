---
layout: layout.njk
title: Panel
---

<div class="space-y-12 py-6">
    
    <a href="/guia" class="block p-10 rounded-3xl bg-slate-900 border border-slate-800 hover:border-emerald-500/30 transition shadow-2xl group">
        <h2 class="text-3xl font-bold text-white mb-2 group-hover:text-emerald-400 transition-colors">Guía Desde Cero</h2>
        <p class="text-slate-400 text-lg">El mapa completo para optimizar tus finanzas desde la base.</p>
    </a>

    <div class="grid gap-8 md:grid-cols-2">
        {% set tools = [
            { 
                title: "Simulador de Jubilación", 
                desc: "Calcula tu pensión futura, último sueldo y equivalente en euros de hoy.", 
                icon: "👴🏼", 
                url: "/apps/jubilacion/", 
                label: "Abrir App interactiva" 
            },
            { 
                title: "Estrategia FIRE", 
                desc: "Modelos de interés compuesto para planificar tu retiro anticipado.", 
                icon: "🛡️", 
                url: "#", 
                label: "Descargar .xlsx" 
            },
            { 
                title: "Fondos Indexados", 
                desc: "Plantillas de rebalanceo global (MSCI World y S&P 500).", 
                icon: "📈", 
                url: "#", 
                label: "Abrir Google Sheets" 
            },
            { 
                title: "Pignoración & Crédito", 
                desc: "Simulador de apalancamiento para obtener liquidez sobre tu cartera.", 
                icon: "🏦", 
                url: "#", 
                label: "Abrir simulador" 
            },
            { 
                title: "Presupuesto Familiar", 
                desc: "Control exhaustivo de gastos, ingresos y fondo de emergencia.", 
                icon: "📊", 
                url: "#", 
                label: "Descargar .xlsx" 
            }
        ] %}
        
        {% for item in tools %}
        <a href="{{ item.url }}" class="group p-8 rounded-2xl bg-slate-900 border border-slate-800 hover:border-slate-600 transition flex flex-col justify-between shadow-lg">
            <div>
                <div class="text-3xl mb-4">{{ item.icon }}</div>
                <h4 class="text-xl font-bold text-white mb-2">{{ item.title }}</h4>
                <p class="text-slate-400 mb-6">{{ item.desc }}</p>
            </div>
            <div class="text-emerald-400 font-mono text-sm">
                <span class="inline-block transition-transform group-hover:translate-x-1">→</span> {{ item.label }}
            </div>
        </a>
        {% endfor %}
    </div>

</div>